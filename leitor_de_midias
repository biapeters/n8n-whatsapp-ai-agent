    {
      "parameters": {
        "jsCode": "const base64Data = $input.first().json.base64; \nconst webhookData = $('When Executed by Another Workflow').first().json.body.data.message.documentMessage;\nconst dadosIniciais = $('Campos Iniciais').first().json;\n\n// Inteligência para garantir a extensão correta caso o WhatsApp não envie o nome do arquivo\nlet nomeArquivo = webhookData.fileName;\n\nif (!nomeArquivo) {\n    const tipo = webhookData.mimetype || '';\n    if (tipo.includes('pdf')) nomeArquivo = 'documento.pdf';\n    else if (tipo.includes('spreadsheetml') || tipo.includes('excel')) nomeArquivo = 'planilha.xlsx';\n    else if (tipo.includes('wordprocessingml') || tipo.includes('msword')) nomeArquivo = 'texto.docx';\n    else nomeArquivo = 'documento.pdf'; // Fallback final de segurança\n}\n\nreturn [{\n    json: dadosIniciais, // Mantém os dados do cliente intactos\n    binary: {\n        file: { \n            data: base64Data,\n            mimeType: webhookData.mimetype, // Puxa o formato original\n            fileName: nomeArquivo \n        }\n    }\n}];"
      },
